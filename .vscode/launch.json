{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ToyRover Debug (SWO)",
            "cwd": "${workspaceFolder}",
            "executable": "build/Debug/ToyRover.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f1x.cfg"
            ],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "swoConfig": {
                "enabled": true,
                "cpuFrequency": 72000000,
                "swoFrequency": 500000,
                "source": "probe",
                "decoders": [
                    {
                        "type": "console",
                        "port": 0,
                        "label": "printf"
                    }
                ]
            }
        }
    ]
}
